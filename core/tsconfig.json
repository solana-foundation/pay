{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "isolatedModules": true,
        "resolveJsonModule": true,
        "strict": true,
        "stripInternal": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": "src",
        "noEmit": false,
        "skipLibCheck": true,
        "lib": ["ES2022"],
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist", "test"]
}
