{
    "name": "@solana/pay",
    "version": "1.0.0",
    "author": "Solana Maintainers <maintainers@solana.foundation>",
    "repository": "https://github.com/solana-foundation/solana-pay",
    "license": "Apache-2.0",
    "type": "module",
    "sideEffects": false,
    "engines": {
        "node": ">=20"
    },
    "files": [
        "dist",
        "src",
        "LICENSE",
        "README.md"
    ],
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "scripts": {
        "clean": "rm -rf dist *.tsbuildinfo || true",
        "build": "tsup",
        "watch": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "fmt": "prettier --write '{*,**/*}.{ts,tsx,js,jsx,json}'",
        "lint": "prettier --check '{*,**/*}.{ts,tsx,js,jsx,json}'",
        "release": "npm run clean && npm run build"
    },
    "dependencies": {
        "@solana/qr-code-styling": "^1.6.0"
    },
    "peerDependencies": {
        "@solana-program/memo": "^0.11.0",
        "@solana-program/system": "^0.12.0",
        "@solana-program/token": "^0.11.0",
        "@solana-program/token-2022": "^0.9.0",
        "@solana/kit": "^6.1.0"
    },
    "devDependencies": {
        "@solana-program/memo": "^0.11.0",
        "@solana-program/system": "^0.12.0",
        "@solana-program/token": "^0.11.0",
        "@solana-program/token-2022": "^0.9.0",
        "@solana/kit": "^6.1.0",
        "@solana/kit-plugins": "^0.5.0",
        "@types/node": "^20.0.0",
        "prettier": "^3.8.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
