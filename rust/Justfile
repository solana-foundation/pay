# Task runner for pay CLI

# Build release binary. On macOS, ad-hoc codesign the result so the
# Keychain ACL recognizes it as a stable identity across rebuilds — without
# this, every fresh build prompts for the login password the first time it
# touches a previously-stored Keychain item.
build:
    cargo build --release
    @just codesign-mac target/release/pay

# Ad-hoc codesign a Mach-O on macOS. No-op on other platforms or if the
# file doesn't exist. Used by `build` and by the top-level `install`
# recipe so the Keychain ACL identity is stable across reinstalls.
codesign-mac PATH:
    @if [ "$(uname)" = "Darwin" ] && [ -f "{{ PATH }}" ]; then \
        codesign --sign - --force "{{ PATH }}"; \
    fi

# Run all tests
test:
    cargo test --workspace

# Run unit tests only
unit-test:
    cargo test --workspace --exclude pay-integration

# Run integration tests only
integration-test:
    cargo test -p pay-integration

# Clippy (warnings = errors)
lint:
    cargo clippy --workspace --all-targets -- -D warnings

# Format check
fmt:
    cargo fmt --check

# Format + lint
check: fmt lint

# Run a workspace binary, forwarding subcommands.
# Examples:
#   just run pay whoami
#   just run pay accounts
#   just run pay account new ludo
run BIN *ARGS:
    cargo run -p {{BIN}} -- {{ARGS}}

# Build Docker image
docker-build:
    DOCKER_BUILDKIT=1 docker build --ssh default -t pay .

# Run Docker image (pass args after --)
docker-run *ARGS:
    docker run --rm pay {{ARGS}}

# Start a payment gateway server
serve SPEC *ARGS:
    cargo run -- server start {{SPEC}} {{ARGS}}

# Start the payment verifier service (for Apigee / external gateways)
apigee-serve *ARGS:
    cargo run -p pay -- server verify {{ARGS}}
